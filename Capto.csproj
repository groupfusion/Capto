<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <StartupObject>Capto.Program</StartupObject>
    <AssemblyName>Capto</AssemblyName>
    <Obfuscate>true</Obfuscate>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Obfuscar" Version="3.0.0-beta.1" />
    <PackageReference Include="QRCoder" Version="1.4.3" />
    <PackageReference Include="System.Management" Version="9.0.0" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="resource\*.png" />
  </ItemGroup>

  <Target Name="ObfuscateAfterBuild" AfterTargets="Publish">
    <PropertyGroup>
      <ObfuscarPath>$(MSBuildThisFileDirectory).nuget\obfuscar\2.6.1\obfuscar.console.exe</ObfuscarPath>
    </PropertyGroup>
    <Exec Command="dotnet $(ObfuscarPath) $(MSBuildThisFileDirectory)Obfuscar.xml" Condition="Exists('$(ObfuscarPath)')" />
  </Target>

</Project>